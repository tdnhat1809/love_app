rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow all read/write access for the love app
    // Couples collection and all subcollections
    match /couples/{coupleId} {
      allow read, write: if true;
      
      match /{subcollection}/{docId} {
        allow read, write: if true;
      }
    }
    
    // Allow any other document access
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
